# Copiar para `.env.local` (Vite carrega automaticamente em dev e build).
# Não commitar `.env.local`.

# Directus (Ask Me → Communication Hub)
VITE_DIRECTUS_URL=https://api.hotelequip.pt
VITE_DIRECTUS_TOKEN=

# Opcional: slugs/campos se diferirem do default
