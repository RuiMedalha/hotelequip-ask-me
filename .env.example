# VITE_DIRECTUS_MESSAGES_COLLECTION=messages
# VITE_DIRECTUS_MESSAGE_CONVERSATION_FIELD=conversation_id
# VITE_DIRECTUS_CONVERSATION_VISITOR_FIELD=visitor_id
